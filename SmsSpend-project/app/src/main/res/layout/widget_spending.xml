<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w_root"
    android:orientation="vertical"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#1E2A38" android:padding="12dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Spent this month" android:textColor="#9FB3C8" android:textSize="12sp"/>
    <TextView android:id="@+id/w_total" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="—"
        android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"/>
    <TextView android:id="@+id/w_text" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Open app to load"
        android:textColor="#CBD5E1" android:textSize="11sp" android:maxLines="4"/>
</LinearLayout>
