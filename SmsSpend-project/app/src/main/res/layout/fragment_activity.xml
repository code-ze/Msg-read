<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout android:orientation="horizontal"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="12dp" android:gravity="center_vertical">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Transactions"
            android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold"/>
        <TextView android:id="@+id/btn_refresh"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⟳ Refresh" android:textColor="@color/teal" android:textSize="14sp"
            android:padding="4dp"/>
    </LinearLayout>

    <!-- Search bar -->
    <EditText android:id="@+id/search_merchant"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:background="@color/card_bg"
        android:padding="12dp"
        android:hint="Search merchant…"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/teal"
        android:textSize="14sp"
        android:inputType="text"
        android:imeOptions="actionSearch"
        android:maxLines="1"/>

    <!-- Filter chips -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:scrollbars="none" android:paddingStart="12dp" android:paddingEnd="12dp"
        android:paddingBottom="8dp">
        <LinearLayout android:orientation="horizontal" android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView android:id="@+id/chip_all"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="All" android:gravity="center" android:paddingStart="16dp"
                android:paddingEnd="16dp" android:textSize="13sp"
                android:textColor="@color/background" android:background="#00C896"
                android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/chip_income"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="Income" android:gravity="center" android:paddingStart="16dp"
                android:paddingEnd="16dp" android:textSize="13sp"
                android:textColor="@color/teal" android:background="#161B22"
                android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/chip_expense"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="Expenses" android:gravity="center" android:paddingStart="16dp"
                android:paddingEnd="16dp" android:textSize="13sp"
                android:textColor="@color/text_secondary" android:background="#161B22"/>
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>
</LinearLayout>
